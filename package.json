{
  "name": "bare-atv",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "make:darwin": "bare-build --out out/bare-atv-darwin-arm64 --host darwin-arm64 --icon icon.png --name BareATV --runtime bare-native/runtime build/index.js",
    "make:android": "bare-build --out out/android-arm64 --resources resources/android --host android-arm64 --manifest manifest.xml --identifier io.bareatv.app --name BareATV --runtime bare-native/runtime build/index.js"
  },
  "imports": {
    "path": {
      "bare": "bare-path",
      "default": "path"
    }
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.21.4",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "bare-build": "^0.5.5",
    "prettier": "^3.8.3",
    "prettier-config-holepunch": "^2.0.0",
    "svelte": "^5.28.2",
    "svelte-check": "^4.1.6",
    "sveltekit-adapter-bare": "^0.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "bare-appletv-remote": "file:../bare-appletv-remote",
    "bare-path": "^3.0.0",
    "bare-storage": "^1.1.0",
    "bare-crypto": "^1.13.6",
    "bare-fetch": "^3.0.1",
    "bare-http1": "^4.5.6",
    "bare-module": "^6.2.0",
    "bare-native": "^0.1.2",
    "bare-process": "^4.4.1"
  }
}
